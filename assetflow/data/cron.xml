<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Daily cron: detect overdue allocations and create reminder activities -->
        <record id="cron_assetflow_overdue_allocations" model="ir.cron">
            <field name="name">AssetFlow: Flag Overdue Allocations</field>
            <field name="model_id" ref="assetflow.model_assetflow_allocation"/>
            <field name="state">code</field>
            <field name="code">model.action_mark_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
