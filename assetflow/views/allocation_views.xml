<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ ALLOCATION — LIST ════════════════════════════════════════════ -->
    <record id="view_assetflow_allocation_list" model="ir.ui.view">
        <field name="name">assetflow.allocation.list</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <tree string="Asset Allocations"
                  decoration-danger="state == 'overdue'"
                  decoration-warning="state == 'transfer_requested'"
                  decoration-success="state == 'returned'"
                  decoration-info="state == 'active'">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="allocation_date"/>
                <field name="expected_return_date"
                       decoration-danger="expected_return_date and expected_return_date &lt; current_date and state == 'active'"/>
                <field name="actual_return_date" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'active'"
                       decoration-warning="state in ['overdue', 'transfer_requested']"
                       decoration-success="state == 'returned'"
                       decoration-danger="state == 'overdue'"/>
                <field name="approved_by_id" widget="many2one_avatar_user" optional="show"/>
                <button name="action_mark_returned" string="Return"
                        type="object" icon="fa-check-circle"
                        invisible="state not in ['active', 'overdue']"/>
                <button name="action_approve_transfer" string="Approve Transfer"
                        type="object" icon="fa-exchange"
                        invisible="state != 'transfer_requested'"
                        groups="assetflow.group_assetflow_manager"/>
            </tree>
        </field>
    </record>

    <!-- ═══ ALLOCATION — FORM ════════════════════════════════════════════ -->
    <record id="view_assetflow_allocation_form" model="ir.ui.view">
        <field name="name">assetflow.allocation.form</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <form string="Asset Allocation">
                <header>
                    <button name="action_mark_returned" string="Mark as Returned"
                            type="object" class="btn-success"
                            invisible="state not in ['active', 'overdue']"/>
                    <button name="action_request_transfer" string="Request Transfer"
                            type="object" class="btn-warning"
                            invisible="state != 'active'"/>
                    <button name="action_approve_transfer" string="Approve Transfer"
                            type="object" class="btn-primary"
                            invisible="state != 'transfer_requested'"
                            groups="assetflow.group_assetflow_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,transfer_requested,overdue,returned"/>
                </header>
                <sheet>
                    <!-- Overdue Alert -->
                    <div class="alert alert-danger mb-3"
                         invisible="state != 'overdue'" role="alert">
                        <h5 class="alert-heading"><i class="fa fa-exclamation-triangle"/> Overdue Return!</h5>
                        This allocation is past its expected return date.
                        Please follow up with <strong><field name="employee_id" readonly="1" nolabel="1"/></strong> immediately.
                    </div>
                    <!-- Transfer Pending Alert -->
                    <div class="alert alert-warning mb-3"
                         invisible="state != 'transfer_requested'" role="alert">
                        <h5 class="alert-heading"><i class="fa fa-exchange"/> Transfer Request Pending</h5>
                        A transfer to <strong><field name="transfer_to_employee_id" readonly="1" nolabel="1"/></strong> is waiting for manager approval.
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Asset">
                            <field name="asset_id"
                                   domain="[('state', '=', 'available')]"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                        <group string="Allocation">
                            <field name="employee_id"/>
                            <field name="allocation_date"/>
                            <field name="expected_return_date"/>
                            <field name="actual_return_date"
                                   invisible="state == 'active'"/>
                            <field name="approved_by_id"/>
                        </group>
                    </group>

                    <group string="Return Details" invisible="state != 'returned'">
                        <field name="return_condition"/>
                        <field name="return_notes"/>
                    </group>

                    <group string="Transfer Request" invisible="state not in ['transfer_requested', 'returned']">
                        <field name="transfer_to_employee_id" readonly="1"/>
                        <field name="transfer_reason" readonly="1"/>
                        <field name="transfer_approved_by_id" readonly="1"
                               invisible="not transfer_approved_by_id"/>
                    </group>

                    <field name="purpose" placeholder="Purpose of allocation, project details, special conditions..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ ALLOCATION — SEARCH ══════════════════════════════════════════ -->
    <record id="view_assetflow_allocation_search" model="ir.ui.view">
        <field name="name">assetflow.allocation.search</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <search string="Search Allocations">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <filter name="active_alloc" string="Active" domain="[('state','=','active')]"/>
                <filter name="overdue" string="Overdue" domain="[('state','=','overdue')]"/>
                <filter name="transfers" string="Pending Transfers" domain="[('state','=','transfer_requested')]"/>
                <filter name="returned" string="Returned" domain="[('state','=','returned')]"/>
                <separator/>
                <filter name="upcoming_return" string="Return Due This Week"
                        domain="[('expected_return_date', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d')), ('state', '=', 'active')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ALLOCATION — WINDOW ACTION ═══════════════════════════════════ -->
    <record id="action_assetflow_allocation" model="ir.actions.act_window">
        <field name="name">Asset Allocations</field>
        <field name="res_model">assetflow.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_assetflow_allocation_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No allocations yet</p>
            <p>Allocate assets to employees. The system prevents double-allocation and supports transfer workflows.</p>
        </field>
    </record>

</odoo>
