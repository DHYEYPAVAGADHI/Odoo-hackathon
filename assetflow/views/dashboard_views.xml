<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════════
         DASHBOARD CLIENT ACTION — Custom QWeb-based KPI Dashboard
    ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- ─── Asset Status Kanban (Dashboard default view) ─────────────────── -->
    <record id="view_assetflow_dashboard_kanban" model="ir.ui.view">
        <field name="name">assetflow.asset.dashboard.kanban</field>
        <field name="model">assetflow.asset</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard o_kanban_small_column"
                    default_group_by="state"
                    quick_create="false"
                    group_create="false"
                    group_delete="false"
                    group_edit="false">
                <field name="name"/>
                <field name="state"/>
                <field name="category_id"/>
                <field name="maintenance_risk"/>
                <field name="cost"/>
                <field name="department_id"/>
                <field name="asset_tag"/>
                <field name="is_bookable_resource"/>
                <field name="current_holder_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_tags_section mt-1">
                                    <span class="badge rounded-pill text-bg-secondary me-1">
                                        <field name="asset_tag"/>
                                    </span>
                                    <span t-if="record.maintenance_risk.raw_value == 'high'"
                                          class="badge rounded-pill text-bg-danger">
                                        ⚠ High Risk
                                    </span>
                                    <span t-elif="record.maintenance_risk.raw_value == 'medium'"
                                          class="badge rounded-pill text-bg-warning text-dark">
                                        ⚡ Med Risk
                                    </span>
                                </div>
                                <ul class="mt-1">
                                    <li t-if="record.category_id.value">
                                        <i class="fa fa-tag me-1 text-muted"/>
                                        <field name="category_id"/>
                                    </li>
                                    <li t-if="record.current_holder_id.value">
                                        <i class="fa fa-user me-1 text-muted"/>
                                        <field name="current_holder_id"/>
                                    </li>
                                    <li t-if="record.department_id.value">
                                        <i class="fa fa-building me-1 text-muted"/>
                                        <field name="department_id"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Asset Status Graph ────────────────────────────────────────────── -->
    <record id="view_assetflow_dashboard_graph" model="ir.ui.view">
        <field name="name">assetflow.asset.dashboard.graph</field>
        <field name="model">assetflow.asset</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <graph string="Asset Portfolio — Status Distribution" type="bar" stacked="True">
                <field name="category_id" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- ─── Asset Portfolio Pivot ─────────────────────────────────────────── -->
    <record id="view_assetflow_dashboard_pivot" model="ir.ui.view">
        <field name="name">assetflow.asset.dashboard.pivot</field>
        <field name="model">assetflow.asset</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <pivot string="Asset Portfolio Analysis" display_quantity="true">
                <field name="department_id" type="row"/>
                <field name="state" type="col"/>
                <field name="cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ─── Allocation Status Graph ──────────────────────────────────────── -->
    <record id="view_assetflow_alloc_dashboard_graph" model="ir.ui.view">
        <field name="name">assetflow.allocation.dashboard.graph</field>
        <field name="model">assetflow.allocation</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <graph string="Allocation Status Overview" type="pie">
                <field name="state" type="row"/>
            </graph>
        </field>
    </record>

    <!-- ─── Booking Graph ────────────────────────────────────────────────── -->
    <record id="view_assetflow_booking_dashboard_graph" model="ir.ui.view">
        <field name="name">assetflow.booking.dashboard.graph</field>
        <field name="model">assetflow.booking</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <graph string="Active Bookings by Resource" type="bar">
                <field name="resource_id" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- ─── Dashboard Window Action ──────────────────────────────────────── -->
    <record id="action_assetflow_dashboard" model="ir.actions.act_window">
        <field name="name">AssetFlow Dashboard</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">kanban,graph,pivot</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_assetflow_dashboard_kanban')}),
            (0, 0, {'view_mode': 'graph',  'view_id': ref('view_assetflow_dashboard_graph')}),
            (0, 0, {'view_mode': 'pivot',  'view_id': ref('view_assetflow_dashboard_pivot')}),
        ]"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to AssetFlow!
            </p>
            <p>
                Start by registering your first asset under <b>Assets → All Assets</b>.<br/>
                Then allocate, book, and maintain it — all from one place.
            </p>
        </field>
    </record>

    <!-- ─── Overdue Allocations Action (Dashboard Quick Link) ────────────── -->
    <record id="action_assetflow_overdue_allocations" model="ir.actions.act_window">
        <field name="name">Overdue Returns</field>
        <field name="res_model">assetflow.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'overdue')]</field>
        <field name="context">{'search_default_overdue': 1}</field>
    </record>

    <!-- ─── Transfer Requests Action (Dashboard Quick Link) ─────────────── -->
    <record id="action_assetflow_transfer_requests" model="ir.actions.act_window">
        <field name="name">Pending Transfers</field>
        <field name="res_model">assetflow.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'transfer_requested')]</field>
    </record>

</odoo>
